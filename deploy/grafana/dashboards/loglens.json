{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loglens-loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "title": "Log volume by severity",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loglens-loki" },
          "expr": "sum by (level) (count_over_time({job=\"loglens\", source=~\"$source\"} [$__auto]))",
          "legendFormat": "{{level}}",
          "queryType": "range"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loglens-loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "yellow", "value": null }, { "color": "red", "value": 5 } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "Total errors + criticals",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loglens-loki" },
          "expr": "sum (count_over_time({job=\"loglens\", source=~\"$source\", level=~\"error|critical\"} [$__range]))",
          "instant": true,
          "queryType": "instant"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loglens-loki" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "options": { "showHeader": true, "sortBy": [ { "displayName": "Value", "desc": true } ] },
      "title": "Top error clusters (by signature)",
      "type": "table",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ],
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loglens-loki" },
          "expr": "topk(15, sum by (cluster, level) (count_over_time({job=\"loglens\", source=~\"$source\", level=~\"warning|error|critical\"} [$__range])))",
          "instant": true,
          "queryType": "instant",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loglens-loki" },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 17 },
      "id": 4,
      "options": { "showLabels": true, "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none", "enableLogDetails": true },
      "title": "Error & critical log lines",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loglens-loki" },
          "expr": "{job=\"loglens\", source=~\"$source\", level=~\"error|critical\"}",
          "queryType": "range"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["loglens"],
  "templating": {
    "list": [
      {
        "name": "source",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loglens-loki" },
        "query": { "label": "source", "stream": "{job=\"loglens\"}", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
